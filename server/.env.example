# --- runtime ---
PORT=4000
NODE_ENV=development

# --- database: 'memory' (no DB needed) or 'mssql' ---
DB_DRIVER=memory

# --- MSSQL (only when DB_DRIVER=mssql). Run server/sql/*.sql first. ---
MSSQL_SERVER=localhost
MSSQL_PORT=1433
MSSQL_DATABASE=HMIS
MSSQL_USER=hmis_app          # EXECUTE-only account — see sql/03_security.sql
MSSQL_PASSWORD=
MSSQL_ENCRYPT=true
MSSQL_TRUST_CERT=false

# --- Redis (optional; in-memory cache used when empty) ---
REDIS_URL=
# REDIS_URL=redis://localhost:6379

# --- auth ---
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=30m

# --- demo seed users' password (memory driver / first MSSQL seed) ---
SEED_PASSWORD=Demo@1234

# --- CORS allowlist (comma separated) ---
CORS_ORIGINS=http://localhost:5173
